{
  "info": {
    "name": "Simple LMS API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for Simple LMS Django Ninja API"
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"student1\",\n  \"email\": \"student1@example.com\",\n  \"password\": \"secret123\",\n  \"role\": \"student\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/register",
          "host": ["{{base_url}}"],
          "path": ["api","auth","register"]
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type","value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"student1\",\n  \"password\": \"secret123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login",
          "host": ["{{base_url}}"],
          "path": ["api","auth","login"]
        }
      }
    },
    {
      "name": "Refresh Token",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type","value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh_token\": \"<REFRESH_TOKEN>\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/refresh",
          "host": ["{{base_url}}"],
          "path": ["api","auth","refresh"]
        }
      }
    },
    {
      "name": "Get Current User",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization","value": "Bearer {{access_token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/api/auth/me",
          "host": ["{{base_url}}"],
          "path": ["api","auth","me"]
        }
      }
    },
    {
      "name": "Update Profile",
      "request": {
        "method": "PUT",
        "header": [
          {"key": "Content-Type","value": "application/json"},
          {"key": "Authorization","value": "Bearer {{access_token}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"student1_updated@example.com\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/me",
          "host": ["{{base_url}}"],
          "path": ["api","auth","me"]
        }
      }
    },
    {
      "name": "List Courses",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/courses?page=1&page_size=10",
          "host": ["{{base_url}}"],
          "path": ["api","courses"],
          "query": [
            {"key": "page", "value": "1"},
            {"key": "page_size", "value": "10"}
          ]
        }
      }
    },
    {
      "name": "Course Detail",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/courses/1",
          "host": ["{{base_url}}"],
          "path": ["api","courses","1"]
        }
      }
    },
    {
      "name": "Create Course",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type","value": "application/json"},
          {"key": "Authorization","value": "Bearer {{access_token}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Python Basics\",\n  \"category_id\": null\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/courses",
          "host": ["{{base_url}}"],
          "path": ["api","courses"]
        }
      }
    },
    {
      "name": "Update Course",
      "request": {
        "method": "PATCH",
        "header": [
          {"key": "Content-Type","value": "application/json"},
          {"key": "Authorization","value": "Bearer {{access_token}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Python Basics Updated\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/courses/1",
          "host": ["{{base_url}}"],
          "path": ["api","courses","1"]
        }
      }
    },
    {
      "name": "Delete Course",
      "request": {
        "method": "DELETE",
        "header": [
          {"key": "Authorization","value": "Bearer {{access_token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/api/courses/1",
          "host": ["{{base_url}}"],
          "path": ["api","courses","1"]
        }
      }
    },
    {
      "name": "Enroll Course",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type","value": "application/json"},
          {"key": "Authorization","value": "Bearer {{access_token}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"course_id\": 1\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/enrollments",
          "host": ["{{base_url}}"],
          "path": ["api","enrollments"]
        }
      }
    },
    {
      "name": "My Courses",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization","value": "Bearer {{access_token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/api/enrollments/my-courses",
          "host": ["{{base_url}}"],
          "path": ["api","enrollments","my-courses"]
        }
      }
    },
    {
      "name": "Mark Lesson Complete",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Authorization","value": "Bearer {{access_token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/api/enrollments/1/progress",
          "host": ["{{base_url}}"],
          "path": ["api","enrollments","1","progress"]
        }
      }
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [],
        "type": "text/javascript"
      }
    }
  ]
}
